      "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
      "apiVersion": "2023-04-01",
      "name": "[format('{0}/{1}', variables('storagePrivateEndpoints')[copyIndex()].name, 'default')]",
      "properties": {
