  "parameters": {
    "environmentName": {
      "type": "string",
      "defaultValue": "logicapp-sample",
      "metadata": {
        "description": "The name of the environment, used to generate all resource names"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "vnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.100.0.0/16"
