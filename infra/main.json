    "storageDnsZoneNames": [
      "[variables('privateStorageFileDnsZoneName')]",
      "[variables('privateStorageBlobDnsZoneName')]",
      "[variables('privateStorageQueueDnsZoneName')]",
      "[variables('privateStorageTableDnsZoneName')]"
    ],
    "storagePrivateEndpoints": [
      {
        "name": "[format('{0}-file-pe', variables('storageAccountName'))]",
        "groupId": "file"
      },
      {
        "name": "[format('{0}-blob-pe', variables('storageAccountName'))]",
        "groupId": "blob"
      },
      {
        "name": "[format('{0}-queue-pe', variables('storageAccountName'))]",
        "groupId": "queue"
      },
      {
        "name": "[format('{0}-table-pe', variables('storageAccountName'))]",
        "groupId": "table"
      }
    ]
  },
  "resources": [
    {
      "type": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "apiVersion": "2018-11-30",
