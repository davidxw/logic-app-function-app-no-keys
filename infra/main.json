    "logicAppSubnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.100.0.0/24"
    },
    "privateEndpointSubnetAddressPrefix": {
      "type": "string",
      "defaultValue": "10.100.1.0/24"
    }
  },
  "variables": {
    "resourceToken": "[toLower(uniqueString(subscription().id, resourceGroup().id, parameters('location')))]",
    "storageAccountName": "[take(toLower(replace(format('st{0}{1}', parameters('environmentName'), variables('resourceToken')), '-', '')), 24)]",
    "logicAppPlanName": "[toLower(format('la-plan-{0}-{1}', parameters('environmentName'), variables('resourceToken')))]",
    "logicAppName": "[toLower(format('la-{0}-{1}', parameters('environmentName'), variables('resourceToken')))]",
    "logicAppIdentityName": "[toLower(format('id-la-{0}-{1}', parameters('environmentName'), variables('resourceToken')))]",
    "logAnalyticsWorkspaceName": "[toLower(format('log-{0}-{1}', parameters('environmentName'), variables('resourceToken')))]",
    "applicationInsightsName": "[toLower(format('appi-{0}-{1}', parameters('environmentName'), variables('resourceToken')))]",
